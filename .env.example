# Copy this to .env and fill in your values

# Mistral API (executor — code generation)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional fallback APIs
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Self-hosted vLLM planner (AMD MI300X or any OpenAI-compatible server)
PLANNER_BASE_URL=http://localhost:8000/v1
PLANNER_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B

# Executor — code generation (default: Mistral Codestral)
# Override these to use any OpenAI-compatible endpoint as executor
EXECUTOR_BASE_URL=https://api.mistral.ai/v1
EXECUTOR_MODEL=codestral-latest
EXECUTOR_API_KEY=               # generic key; falls back to MISTRAL_API_KEY if empty
EXECUTOR_CONTEXT_LIMIT=0        # 0 = auto-detect from backend

# Agent settings
MAX_ROUNDS=9
DEFAULT_BACKEND=mistral

# Optional: HuggingFace token for model downloads
HUGGINGFACE_TOKEN=your_hf_token_here
